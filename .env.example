# TapTap MCP Server Configuration
# Copy this file to .env and update with your values

# ============================================
# 认证配置（可选 - 推荐使用 OAuth）
# ============================================

# 用户 MAC Token（JSON 格式）
# 不配置则使用 OAuth 2.0 Device Code Flow，Token 自动保存到 ~/.config/taptap-minigame/token.json
# TDS_MCP_MAC_TOKEN='{"kid":"your_kid","token_type":"mac","mac_key":"your_key","mac_algorithm":"hmac-sha-1"}'

# ============================================
# 客户端配置（可选 - 已内置默认值）
# ============================================

# 客户端 ID（已内置，一般无需配置）
# TDS_MCP_CLIENT_ID=your_client_id

# 请求签名密钥（必需，已内置默认值）
# TDS_MCP_CLIENT_TOKEN=your_client_token

# ============================================
# 环境和传输配置
# ============================================

# 环境选择（默认: production）
# production: https://agent.tapapis.cn
# rnd: https://agent.api.xdrnd.cn
TDS_MCP_ENV=production

# 传输协议（默认: stdio）
# stdio: 标准输入输出，适合本地集成（Claude Desktop、Cursor）
# sse: SSE 流式响应，支持实时进度和自动授权（推荐用于 OpenHands）
# http: JSON 单次响应，适合普通 HTTP 客户端
TDS_MCP_TRANSPORT=stdio

# HTTP/SSE 模式的监听端口（默认: 3000）
TDS_MCP_PORT=3000

# 项目路径（用于本地缓存，已废弃）
# 注意：v1.4.1+ 使用独立的缓存和临时目录，不再使用此选项
# TDS_MCP_PROJECT_PATH=/path/to/your/project

# 缓存根目录（默认: /tmp/taptap-mcp/cache）
# 应用信息缓存存储位置，独立于 workspace
# TDS_MCP_CACHE_DIR=/var/lib/taptap-mcp/cache

# 临时文件根目录（默认: /tmp/taptap-mcp/temp）
# H5 游戏压缩包等临时文件存储位置
# TDS_MCP_TEMP_DIR=/tmp/taptap-mcp/temp

# 详细日志模式（默认: false）
# true: 记录所有工具调用、HTTP 请求/响应
# false: 只记录关键信息
TDS_MCP_VERBOSE=false

# ============================================
# 使用示例
# ============================================

# 本地开发（stdio 模式）：
#   TDS_MCP_TRANSPORT=stdio
#   npm start

# OpenHands 部署（SSE 模式）：
#   TDS_MCP_TRANSPORT=sse
#   TDS_MCP_PORT=3000
#   TDS_MCP_VERBOSE=true
#   npm run serve:sse

# 普通 HTTP 客户端（HTTP JSON 模式）：
#   TDS_MCP_TRANSPORT=http
#   TDS_MCP_PORT=3000
#   npm run serve:http
