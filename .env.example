# TapTap API 配置（可选 - 未设置时使用模拟数据）
# TAPTAP_API_KEY=your-taptap-api-key-here
TAPTAP_API_BASE_URL=https://api.taptap.com/v1
TAPTAP_ENVIRONMENT=production

# MCP 服务器配置
MCP_SERVER_NAME=taptap-minigame
MCP_SERVER_VERSION=1.0.0
MCP_LOG_LEVEL=INFO

# 缓存配置
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# 限流配置
RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=1000

# 数据库配置（可选）
DATABASE_URL=sqlite:///./taptap_mcp.db

# 监控配置
PROMETHEUS_PORT=8000
ENABLE_METRICS=true

# 开发配置
DEBUG=false
DEV_MODE=false